# Copy to .env and fill in real values (never commit .env)

# App URL path under the domain (no trailing slash).
# Root deploy (files in public_html): leave empty or omit — auto-detects "" for eventifywlc.com/
# Local XAMPP subfolder: BASE_URL=/school_events
BASE_URL=

# Database — local XAMPP defaults; override on GoDaddy/cPanel (see config/db.local.php.example)
DB_HOST=localhost
DB_USER=eventify_user
DB_PASS="jVwK!;Cu}sgh6vET"
DB_NAME=eventify

# Set to true when deploying (requires GPS within EVENTIFY_CHECKIN_GEO_RADIUS_M of pinned venue)
# EVENTIFY_CHECKIN_GEO_WHEN_PINNED=true

# Local dev: Gmail. GoDaddy live: relay-hosting.secureserver.net port 25 (see smtp.production.godaddy.php.example)
EVENTIFY_SMTP_HOST=smtp.gmail.com
EVENTIFY_SMTP_PORT=587
EVENTIFY_SMTP_USERNAME=
EVENTIFY_SMTP_PASSWORD=
EVENTIFY_SMTP_FROM_EMAIL=
EVENTIFY_SMTP_FROM_NAME=EVENTIFY
EVENTIFY_SMTP_ALLOW_INSECURE_TLS=false
# GoDaddy relay (production): set NO_AUTH=true, DISABLE_TLS=true, PORT=25, FROM_EMAIL=@yourdomain.com
# EVENTIFY_SMTP_HOST=relay-hosting.secureserver.net
# EVENTIFY_SMTP_PORT=25
# EVENTIFY_SMTP_NO_AUTH=true
# EVENTIFY_SMTP_DISABLE_TLS=true
# EVENTIFY_SMTP_EHLO_HOST=eventifywlc.com
# EVENTIFY_SMTP_FROM_EMAIL=noreply@eventifywlc.com

SEMAPHORE_API_KEY=
SEMAPHORE_SENDER_NAME=

# Web Push (generate with: php tools/generate_vapid_openssl.php)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Cron secret for scheduled jobs (event reminders). Use a long random string.
# GoDaddy cron URL: https://yoursite.com/backend/cron/send_event_reminders.php?key=YOUR_KEY
EVENTIFY_CRON_KEY=
