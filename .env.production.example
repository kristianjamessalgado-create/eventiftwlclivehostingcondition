# GoDaddy / live server (.env) — copy to .env on the HOSTING server only.
# Do NOT use this file on your laptop/PC for local XAMPP work.
# For local dev, copy .env.example → .env instead.

# Root deploy on eventifywlc.com (files in public_html)
BASE_URL=

# MySQL — from GoDaddy cPanel → MySQL Databases
DB_HOST=localhost
DB_USER=your_cpanel_mysql_user
DB_PASS=your_mysql_password
DB_NAME=eventify

# GoDaddy relay (see config/smtp.production.godaddy.php.example)
EVENTIFY_SMTP_HOST=relay-hosting.secureserver.net
EVENTIFY_SMTP_PORT=25
EVENTIFY_SMTP_NO_AUTH=true
EVENTIFY_SMTP_DISABLE_TLS=true
EVENTIFY_SMTP_EHLO_HOST=eventifywlc.com
EVENTIFY_SMTP_FROM_EMAIL=noreply@eventifywlc.com
EVENTIFY_SMTP_FROM_NAME=EVENTIFY

# Web Push — generate once, use the SAME keys on live server
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@eventifywlc.com

# Cron: https://eventifywlc.com/backend/cron/send_event_reminders.php?key=YOUR_KEY
EVENTIFY_CRON_KEY=
